# Crawl4AI MCP Server 环境变量配置示例
# 复制此文件为 .env 并填入实际的值

# ============================================
# API 密钥配置
# ============================================

# 在 config.json 缺省时,容器会自动读取这些变量,因此用户无需再传入密钥
# (复制为 .env 后即可生效, `make docker-up` 会自动加载)

# Google Custom Search API
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-google-cse-id-here

# Brave Search API
BRAVE_API_KEY=your-brave-api-key-here

# ============================================
# 代理配置（可选）
# ============================================

# HTTP/HTTPS 代理 (供全局回退使用)
# Docker 模式推荐直接复用宿主机 Clash:
HTTP_PROXY=http://host.docker.internal:7890
HTTPS_PROXY=http://host.docker.internal:7890
NO_PROXY=localhost,127.0.0.1,.local,searxng
http_proxy=http://host.docker.internal:7890
https_proxy=http://host.docker.internal:7890
no_proxy=localhost,127.0.0.1,.local,searxng
# 如果直接在宿主机运行, 可切换为 127.0.0.1:
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# DuckDuckGo 专用代理 (可选)
# DUCKDUCKGO_PROXY=http://127.0.0.1:7890

# Brave 专用代理 (可选)
# BRAVE_PROXY=http://127.0.0.1:7890

# Google 专用代理 (可选)
# GOOGLE_PROXY=http://127.0.0.1:7890

# SearXNG 专用代理 (可选)
# SEARXNG_PROXY=http://127.0.0.1:7890

# SOCKS5 代理示例（注意：部分引擎可能不支持）
# HTTP_PROXY=socks5h://127.0.0.1:7890
# HTTPS_PROXY=socks5h://127.0.0.1:7890

# 容器内访问宿主机代理(如 Clash) 的辅助开关
# 将以下变量设置为真时,会把所有指向 127.0.0.1/localhost 的代理 URL
# 重写为 host.docker.internal (或你指定的 gateway),解决 ERR_PROXY_CONNECTION_FAILED
CRAWL4AI_ALLOW_PROXY_REWRITE=true
# 如 Clash 监听在宿主机 7890/7891 端口,可在这里重写端口 (1-65535)
HOST_PROXY_PORT_OVERRIDE=7890
# Linux 用户若启用了 `extra_hosts: host.docker.internal:host-gateway`,无需修改
# 若网关不同,可填宿主机 IP
HOST_PROXY_GATEWAY=host.docker.internal

# ============================================
# SearXNG 配置（可选）
# ============================================

# 默认指向 docker-compose 中的 searxng 服务
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_LANGUAGE=zh-CN

# 若你在宿主机上单独运行 SearXNG, 请改为:
# SEARXNG_BASE_URL=http://host.docker.internal:28981
# 或者在本机直接运行时使用:
# SEARXNG_BASE_URL=http://127.0.0.1:28981

# ============================================
# auto 模式质量增强（可选）
# ============================================

# 开启后，auto 模式会在满足数量后继续尝试更多引擎，并将结果 merge+去重+按优先级排序
# 用于缓解单一引擎在某些网络/区域环境下“能返回但质量很差”的情况。
CRAWL4AI_AUTO_MERGE=0
# 最少尝试多少个引擎（默认 2）
CRAWL4AI_AUTO_MERGE_MIN_ENGINES=2
# 最多尝试多少个引擎（默认 3）
CRAWL4AI_AUTO_MERGE_MAX_ENGINES=3

# ============================================
# 多引擎融合排序（可选，提升 TopN 质量）
# ============================================

# 当使用 all 模式或 auto-merge 合并多引擎结果时的融合策略：
# - rrf: Reciprocal Rank Fusion（推荐，通常更稳健）
# - priority: 按引擎优先级 + 原始顺序（旧策略）
CRAWL4AI_FUSION_METHOD=rrf

# RRF 参数 k（越大越“平滑”，默认 60）
CRAWL4AI_RRF_K=60

# 引擎权重（可选）。JSON 或 key=value 列表均可：
# CRAWL4AI_RRF_ENGINE_WEIGHTS={"google":1.0,"brave":0.9,"searxng":0.7,"duckduckgo":0.4}
# CRAWL4AI_RRF_ENGINE_WEIGHTS=google=1.0,brave=0.9,searxng=0.7,duckduckgo=0.4
# CRAWL4AI_RRF_ENGINE_WEIGHTS=

# 域名权威性加权（可选，官方站 boost）：用于“官方入口优先”的业务场景。
# 支持 JSON 或 key=value 列表：
# CRAWL4AI_DOMAIN_BOOSTS={"iter.org":1.35,"iaea.org":1.25,"fusionforenergy.europa.eu":1.25,"euro-fusion.org":1.2,"pppl.gov":1.15}
# CRAWL4AI_DOMAIN_BOOSTS=iter.org=1.35,iaea.org=1.25,fusionforenergy.europa.eu=1.25,euro-fusion.org=1.2,pppl.gov=1.15
# 说明：匹配规则为 host == domain 或 host 以 .domain 结尾（会自动忽略 www.）。
# CRAWL4AI_DOMAIN_BOOSTS=

# ============================================
# 应用配置
# ============================================

# 缓存配置
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# 缓存后端选择（推荐 Docker 用 persistent）
# - memory: 仅内存缓存（默认）
# - persistent/sqlite: SQLite 持久化缓存（跨重启保留，适合 Docker）
CRAWL4AI_CACHE_BACKEND=memory
# 或者使用这个开关（二选一即可）：
# CRAWL4AI_ENABLE_PERSISTENT_CACHE=true

# SQLite 持久化缓存配置（仅当启用 persistent 时生效）
# 容器内默认写到 /app/cache/search_cache.db（docker-compose 已挂载 /app/cache）
CRAWL4AI_PERSISTENT_CACHE_DB_PATH=cache/search_cache.db
CRAWL4AI_PERSISTENT_CACHE_MAX_SIZE=10000
# 是否启用内存热缓存（命中过一次的 key 会留在内存里，加速后续访问）
CRAWL4AI_PERSISTENT_CACHE_MEMORY=true

# 限流配置
ENABLE_RATE_LIMIT=true

# ============================================
# 超时预算 & 并发舱壁（bulkhead，可选，提升稳定性/尾延迟）
# ============================================

# 单次 search 的总体 deadline（秒）。超过后会返回空结果并记录错误，
# 同时确保 in-flight coalescing 任务会及时退出并清理。
# 设为空/0 可关闭。
# CRAWL4AI_SEARCH_DEADLINE_S=30

# 单个引擎的总体预算（秒），覆盖重试/backoff（即 _search_with_retry 的整体耗时）。
# 设为空/0 可关闭。
# CRAWL4AI_ENGINE_TIMEOUT_S=20
# 可按引擎分别覆盖：
# CRAWL4AI_ENGINE_TIMEOUT_GOOGLE_S=15
# CRAWL4AI_ENGINE_TIMEOUT_BRAVE_S=15
# CRAWL4AI_ENGINE_TIMEOUT_SEARXNG_S=10
# CRAWL4AI_ENGINE_TIMEOUT_DUCKDUCKGO_S=15

# ============================================
# 引擎级熔断（Circuit Breaker，可选，提升稳定性/尾延迟）
# ============================================

# 启用引擎级熔断（默认开启）。设为 0/false/off 可关闭。
CRAWL4AI_ENGINE_CIRCUIT_BREAKER=1

# 连续失败次数达到阈值后打开熔断（默认 5）
CRAWL4AI_CB_FAILURE_THRESHOLD=5

# 熔断打开后保持多久（秒，默认 30）。到期后进入 HALF_OPEN，允许一次探测请求。
CRAWL4AI_CB_OPEN_SECONDS=30

# 可按引擎分别覆盖：
# CRAWL4AI_CB_FAILURE_THRESHOLD_GOOGLE=3
# CRAWL4AI_CB_OPEN_SECONDS_GOOGLE=60
# CRAWL4AI_CB_FAILURE_THRESHOLD_BRAVE=3
# CRAWL4AI_CB_OPEN_SECONDS_BRAVE=60
# CRAWL4AI_CB_FAILURE_THRESHOLD_SEARXNG=3
# CRAWL4AI_CB_OPEN_SECONDS_SEARXNG=30
# CRAWL4AI_CB_FAILURE_THRESHOLD_DUCKDUCKGO=3
# CRAWL4AI_CB_OPEN_SECONDS_DUCKDUCKGO=60

# 全局最大并发搜索请求（进程内）。设为 0 可关闭全局并发限制。
# CRAWL4AI_MAX_CONCURRENT_SEARCHES=20

# 每引擎最大并发（进程内）。设为 0 可关闭“默认每引擎”限制。
# CRAWL4AI_MAX_CONCURRENT_PER_ENGINE=5
# 或按引擎覆盖：
# CRAWL4AI_MAX_CONCURRENT_GOOGLE=3  # 设为 0 可关闭该引擎的限制
# CRAWL4AI_MAX_CONCURRENT_BRAVE=3
# CRAWL4AI_MAX_CONCURRENT_SEARXNG=5
# CRAWL4AI_MAX_CONCURRENT_DUCKDUCKGO=5

# 监控配置
ENABLE_MONITORING=true

# ============================================
# 并发请求合并（request coalescing，可选）
# ============================================

# 开启后：相同 (query, engine, num_results) 的并发请求会共享同一个“在途”上游调用，
# 避免并发时重复打外部搜索引擎，降低限流/封禁风险，并改善尾延迟。
# 默认行为：未设置时视为开启。
# 设为 0/false/off 可关闭。
CRAWL4AI_ENABLE_REQUEST_COALESCING=1

# ============================================
# read_url 安全防护（SSRF/重定向/体积/类型，可选，建议对外服务开启）
# ============================================

# SSRF 基线防护（默认开启）：仅允许 http/https，并阻止访问非公网地址
# 如需关闭（不推荐）：
# CRAWL4AI_READ_URL_SSRF_PROTECTION=0

# 是否允许访问私网/localhost（默认 0，不允许；强烈不建议对公网开启）
# CRAWL4AI_READ_URL_ALLOW_PRIVATE=0

# 允许的主机白名单（逗号分隔）。在 SSRF 防护开启时仍可放行指定域名。
# 例如：允许内部文档站（仅限内网部署场景）
# CRAWL4AI_READ_URL_ALLOWED_HOSTS=docs.internal.example.com

# URL 最大长度（默认 4096）
# CRAWL4AI_READ_URL_MAX_URL_LENGTH=4096

# 预检（preflight）开关：在真正启动浏览器爬取前，用 httpx 做一次轻量请求以限制
# - 最大重定向次数
# - Content-Type 白名单
# - 响应体大小上限
# 默认关闭（避免额外网络开销与误判）；对外服务建议开启。
# CRAWL4AI_READ_URL_PREFLIGHT=1

# 预检超时（秒，默认 5）
# CRAWL4AI_READ_URL_PREFLIGHT_TIMEOUT_S=5

# 最大重定向次数（默认 5）
# CRAWL4AI_READ_URL_MAX_REDIRECTS=5

# 预检响应体最大字节（默认 2MiB）。超出则直接拒绝。
# CRAWL4AI_READ_URL_PREFLIGHT_MAX_BYTES=2097152

# 允许的 Content-Type 前缀（逗号分隔）。默认允许 HTML/XHTML/text/plain/json。
# CRAWL4AI_READ_URL_ALLOWED_CONTENT_TYPES=text/html,application/xhtml+xml

# ============================================
# 多引擎并发 early-return（可选，显著降低尾延迟）
# ============================================

# all 模式：并发搜索时，满足条件后提前返回并取消慢引擎。
# 默认关闭以保持“尽量用全引擎融合”的语义。
# CRAWL4AI_ALL_EARLY_RETURN=1
# 至少需要多少个引擎返回了非空结果才允许 early-return（默认 1）
# CRAWL4AI_ALL_EARLY_RETURN_MIN_ENGINES=1
# 达到条件后额外等待一小段 grace time（秒），用于捞到“差一点就返回”的引擎（默认 0）
# CRAWL4AI_ALL_EARLY_RETURN_GRACE_S=0.2

# auto-merge：将原本串行尝试的引擎改为并发，并支持 early-return。
# 需要同时开启 CRAWL4AI_AUTO_MERGE=1 才生效。
# CRAWL4AI_AUTO_MERGE_CONCURRENT=1
# CRAWL4AI_AUTO_MERGE_EARLY_RETURN=1

# ============================================
# 检索效果回归评测（golden queries，可选）
# ============================================

# 运行脚本：scripts/retrieval_eval.py
# - offline 模式（推荐用于 CI/PR 门禁）：读取一个固定 results.json 来评分
# - live 模式（更贴近真实体验）：实际发起搜索引擎请求，波动较大，建议 nightly/手动跑

# live 模式指定引擎（默认 all）
# CRAWL4AI_EVAL_ENGINE=all

# offline 模式指定 results JSON 路径
# CRAWL4AI_EVAL_RESULTS_JSON=output/llm_search_results.json

# （可选）Baseline 报告路径：用于“当前评测 vs 基线评测”的回归对比
# CRAWL4AI_EVAL_BASELINE_REPORT=eval/baselines/retrieval_eval_baseline.json

# （可选）分桶统计字段：逗号分隔。默认 theme,language,intent
# 设为空字符串可禁用分桶输出
# CRAWL4AI_EVAL_BUCKET_BY=theme,language,intent

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/app/logs/crawl4ai.log

# ============================================
# 服务器配置
# ============================================

# ============================================
# HTTP Bridge 安全壳（建议生产开启）
# ============================================

# 1) Bearer Token 鉴权
# - 若设置了 token，则 /search 与 /read_url 会强制要求：
#   Authorization: Bearer <token>
# - 若未设置 token，HTTP Bridge 将保持“无鉴权”兼容行为（但会在启动时打印警告）。
# CRAWL4AI_HTTP_AUTH_TOKEN=your-long-random-token
# 可用于滚动/多客户端：逗号分隔多个 token
# CRAWL4AI_HTTP_AUTH_TOKENS=token1,token2
# 是否也保护 /health（默认不保护，方便 docker healthcheck）
# CRAWL4AI_HTTP_PROTECT_HEALTH=0

# 2) HTTP 层限流（令牌桶）。不设置/<=0 即关闭。
# 每秒允许多少个请求（RPS）
# CRAWL4AI_HTTP_RATE_LIMIT_RPS=5
# 突发容量（burst，默认 5）
# CRAWL4AI_HTTP_RATE_LIMIT_BURST=10

# 3) 请求体大小限制（字节）。默认 1MiB。
# 设为 0 可关闭（不推荐）。
# CRAWL4AI_HTTP_MAX_BODY_BYTES=1048576

# 4) 单个 HTTP 请求的超时（秒）。默认 60。
# 设为 0 可关闭（不推荐）。
# CRAWL4AI_HTTP_REQUEST_TIMEOUT_S=60

# 服务端口
SERVER_PORT=8000

# 健康检查
HEALTH_CHECK_ENABLED=true

# ----------------------------------------------------------------
# Fusion Terms 集成（可选）
# ----------------------------------------------------------------
# 指向 fusion-terms 项目产出物目录（artifacts/），
# 用于聚变/核工程领域的术语规范化、查询扩展和相关性增强。
# 不设置或路径不存在时：零开销，完全透明。
#
# FUSION_TERMS_ARTIFACTS_DIR=/home/gw/opt/fusion-terms/artifacts
